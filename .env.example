# Gemini API 設定のテンプレート。実際の値を入れた .env を各自作成すること（.env は .gitignore 済み）。
#   cp .env.example .env  してから値を埋める
GEMINI_API_NAME=KHR_tora
GEMINI_API_KEY=your-gemini-api-key-here
# 性能の高い順のフォールバックチェーン（上限/利用不可で次モデルへ）
GEMINI_MODELS=gemini-3.5-flash,gemini-3.1-flash-lite,gemini-2.5-flash
# 後方互換（GEMINI_MODELS 未設定時のみ使用）
GEMINI_MODEL=gemini-3.5-flash
